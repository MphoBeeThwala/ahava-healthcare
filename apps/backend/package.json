{
  "name": "@ahava-healthcare/api",
  "version": "1.0.0",
  "description": "Ahava Healthcare Backend API - Express.js with Prisma",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma generate --schema=prisma/schema.prisma && tsx watch src/index.ts",
    "build": "prisma generate --schema=prisma/schema.prisma && tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --config eslint.config.cjs",
    "lint:fix": "eslint src --fix --config eslint.config.cjs",
    "type-check": "prisma generate --schema=prisma/schema.prisma && tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "node scripts/generate-prisma-postinstall.js || node scripts/check-prisma.js || echo Prisma check completed",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:check": "node scripts/check-prisma.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx src/seed.ts",
    "seed:mock-patients": "tsx src/scripts/seed-mock-patients.ts",
    "seed:from-synthea": "tsx src/scripts/seed-from-synthea.ts",
    "db:reset": "prisma migrate reset --force",
    "validate:env": "node scripts/validate-env.js"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "6.19.3",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.67.2",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "redis": "^4.7.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "morgan": "^1.10.0",
    "pdfkit": "^0.14.0",
    "resend": "^4.0.0",
    "sharp": "^0.33.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/supertest": "^2.0.16",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.55.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "prisma": "6.19.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^7.0.0"
  }
}
