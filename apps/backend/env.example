# Database
DATABASE_URL="postgresql://username:password@localhost:5432/ahava-healthcare?schema=public"

# JWT & Auth
JWT_SECRET="your-super-secret-jwt-key-32-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# OAuth2 PKCE
OAUTH_PKCE_CLIENT_ID="your-oauth-client-id"
OAUTH_PKCE_ISSUER="https://your-auth-provider.com"
OAUTH_REDIRECT_URI="http://localhost:3000/auth/callback"

# Paystack
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key"
PAYSTACK_PUBLIC_KEY="pk_test_your_paystack_public_key"
PAYSTACK_WEBHOOK_SECRET="your_paystack_webhook_secret"

# Redis
REDIS_URL="redis://localhost:6379"

# Expo Push Notifications
EXPO_ACCESS_TOKEN="your_expo_access_token"

# Encryption
ENCRYPTION_KEY="base64-encoded-32-byte-key"
# Legacy-only (kept for backward decryption compatibility). Not used for new encryptions.
ENCRYPTION_IV_SALT="hex-encoded-16-byte-salt"

# Server
PORT=4000
NODE_ENV="development"
TIMEZONE="Africa/Johannesburg"

# API
OPENAPI_BASE_URL="http://localhost:4000"

# Storage
EXPORT_STORAGE_DIR="./exports"

# Email – Resend (for post-interaction notifications: receipts, triage, visit approval, prescriptions)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="Ahava Healthcare <notifications@yourdomain.com>"

# Email (Mailhog for development – optional if using Resend)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@ahavahealthcare.co.za"

# ROOK (wearables)
# Sandbox:    https://api.rook-connect.review/api/v1
# Production: https://api.rook-connect.com/api/v1
ROOK_BASE_URL="https://api.rook-connect.review/api/v1"
ROOK_CLIENT_UUID=""
ROOK_SECRET_KEY=""
ROOK_WEBHOOK_SECRET=""
# Optional legacy compatibility. Keep false unless you explicitly need old /auth/session flow.
ROOK_ENABLE_LEGACY_SESSION_FALLBACK="false"

# Terra webhook signature secret
TERRA_WEBHOOK_SECRET=""

# Enforce signed webhook verification in production
WEBHOOK_SIGNATURE_REQUIRED="true"

# Shared secret for backend -> ML service calls
ML_SERVICE_SHARED_SECRET=""

# Rate limiting (tune in staging/load tests)
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="100"
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX="30"
# AUTH_RATE_LIMIT_KEY_STRATEGY: ip | email | ip_or_email
AUTH_RATE_LIMIT_KEY_STRATEGY="ip"
WEBHOOK_RATE_LIMIT_WINDOW_MS="60000"
WEBHOOK_RATE_LIMIT_MAX="50"

# Idempotency (critical POST deduplication)
IDEMPOTENCY_TTL_SECONDS="900"
IDEMPOTENCY_LOCK_SECONDS="60"

# Resilient external HTTP (ROOK/ML retries + circuit breaker)
HTTP_RETRY_MAX_RETRIES="2"
HTTP_RETRY_TIMEOUT_MS="8000"
HTTP_RETRY_BACKOFF_MS="250"
HTTP_CIRCUIT_THRESHOLD="5"
HTTP_CIRCUIT_OPEN_MS="15000"
