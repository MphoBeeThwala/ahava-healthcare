{
  "name": "ahava-healthcare",
  "version": "1.0.0",
  "description": "Ahava Healthcare - Full-stack healthcare platform for South Africa - patient bookings, nurse home visits, doctor oversight",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "workspace"
  ],
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "build:frontend": "yarn workspace workspace build",
    "start:frontend": "yarn workspace workspace start",
    "dev": "yarn workspaces foreach -Ap run dev",
    "dev:api": "yarn workspace @ahava-healthcare/api dev",
    "dev:worker": "yarn workspace @ahava-healthcare/worker dev",
    "test": "yarn workspaces foreach -A run test",
    "test:backend": "yarn workspace @ahava-healthcare/api test",
    "lint": "yarn workspaces foreach -A run lint",
    "lint:fix": "yarn workspaces foreach -A run lint:fix",
    "type-check": "yarn workspaces foreach -A run type-check",
    "clean": "yarn workspaces foreach -A run clean",
    "prisma:generate": "yarn workspace @ahava-healthcare/api prisma:generate",
    "prisma:migrate": "yarn workspace @ahava-healthcare/api prisma:migrate",
    "prisma:seed": "yarn workspace @ahava-healthcare/api prisma:seed",
    "seed:mock-patients": "yarn workspace @ahava-healthcare/api seed:mock-patients",
    "seed:from-synthea": "yarn workspace @ahava-healthcare/api seed:from-synthea",
    "synthea:run-and-seed": "node scripts/run-synthea-and-seed.js",
    "load-test:patient-pipeline": "node scripts/load-test-patient-pipeline.js",
    "test:early-warning": "node scripts/run-early-warning-test.js",
    "test:services": "node scripts/test-services.js",
    "db:reset": "yarn workspace @ahava-healthcare/api db:reset",
    "build:capacitor": "yarn exec vite build --config vite.capacitor.config.ts",
    "cap:sync": "yarn build:capacitor && yarn exec cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.12.0",
    "capacitor-health": "^8.1.0",
    "chart.js": "^4.4.0",
    "lucide-react": "^0.263.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^6.8.0",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.1.0",
    "puppeteer": "^24.37.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=4.0.0"
  }
}
